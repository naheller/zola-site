<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="utf-8">
  <title>
    {% if page.title %}
    {{ page.title }} - {{ config.title }}
    {% elif section.title %}
    {{ section.title }} - {{ config.title }}
    {% else %}
    {{ config.title }}
    {% endif %}
  </title>
  <link rel="stylesheet" href="/styles/normalize.css">
  <link rel="stylesheet" href="/styles/styles.css">
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
</head>

<body>
  <header>
    <h1 class="title">
    {% if page.title %}
    {{ page.title }}
    {% elif section.title %}
    {{ section.title }}
    {% else %}
    {{ config.title }}
    {% endif %}
    </h1>
    {% if page.description %}
    <p class="description">{{ page.description }}</p>
    {% elif section.description %}
    <p class="description">{{ section.description }}</p>
    {% elif current_path == "/" %}
    <p class="description">{{ config.description }}</p>
    {% endif %}
    {% if page.date %}
    <p class="date">
      <time datetime="{{ page.date }}">
	{{ page.date | date(format="%b %-d, %Y") }}
      </time>
    </p>
    {% endif %}
  </header>
  <hr />
  {% if page.extra.centered %}
  <main class="centered-blurb">
  {% else %}
  <main>
  {% endif %}
  {% block content %} {% endblock content %}
  {% if current_path is starting_with("/blog") %}
  <div class="next-previous">
  {% if page.lower %}
    <a href="{{ page.lower.permalink | safe }}">&lsaquo;&lsaquo; Previous post</a>
{% endif %}
{% if page.higher %}
    <a href="{{ page.higher.permalink | safe }}">Next post &rsaquo;&rsaquo;</a>
    {% endif %}
  </div>
  {% endif %}
  </main>
  <hr />
  <footer>
    {% include "navbar.html" %}
  </footer>
</body>

</html>
